####################################
# Gradle / Build outputs
####################################
.gradle/
**/.gradle/
build/
**/build/

# Gradle local properties (SDK path, etc.)
local.properties

# Gradle GUI
gradle-app.setting

# Build scans / temp
out/
tmp/

####################################
# Kotlin / KSP / KAPT / Compose
####################################
# Kotlin compiler caches
.kotlin/
**/.kotlin/

# KSP / KAPT generated sources (generated, do not commit)
**/build/generated/ksp/
**/build/generated/source/kapt/
**/build/generated/source/kaptKotlin/
**/kaptKotlin/

# Compose compiler reports (optional)
**/build/compose_compiler/
**/build/reports/compose/

